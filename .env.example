# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/kyc-game-platform

# JWT
JWT_SECRET=your-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=kyc-game-documents

# App Config
# Set APP_ENV to "prod" for production (uses infradaily.dev URLs) or "dev" for local development
APP_ENV=prod
NEXT_PUBLIC_APP_ENV=prod

GAME_WEBGL_URL=https://your-deployed-webgl-game.com
# Dev URLs (used when APP_ENV=dev)
API_URL=http://localhost:5001
ONBOARDING_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:5001
# Prod URLs (auto-applied when APP_ENV=prod — no need to set manually)
# API_URL=https://api.infradaily.dev
# ONBOARDING_URL=https://app.infradaily.dev
# ADMIN_URL=https://admin.infradaily.dev
# NEXT_PUBLIC_API_URL=https://api.infradaily.dev

# Optional — Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email
SMTP_PASS=your-app-password
